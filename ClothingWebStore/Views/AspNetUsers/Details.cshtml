@model Microsoft.AspNetCore.Identity.IdentityUser
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

<h2>User Details</h2>

<div class="card p-3">
    <p><strong>Email:</strong> @Model.Email</p>
    <p><strong>User ID:</strong> @Model.Id</p>
    <p><strong>Email confirmed:</strong> @Model.EmailConfirmed</p>

    <hr />

    <h5>Roles</h5>
    <ul>
        @{
            var roles = await UserManager.GetRolesAsync(Model);

            foreach (var role in roles)
            {
                <li>@role</li>
            }
        }
    </ul>
</div>

<a asp-action="Index" class="btn btn-secondary mt-3">Back</a>