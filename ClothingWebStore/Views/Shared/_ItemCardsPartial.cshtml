@model ClothingWebStore.Models.Product
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

<div class="col-lg-3 col-md-4 col-sm-6">

    <div class="card product-card h-100 shadow-sm">

        <img class="card-img-top product-image"
             src="@(Model.ProductImages.FirstOrDefault()?.ImageUrl ?? "/images/no-image.png")"
             alt="Product Image">

        <div class="card-body text-center">

            <h6 class="text-muted">@Model.Manufacturer.Name</h6>

            <h5 class="fw-bold">@Model.Name</h5>

            <p class="price">@Model.Price.ToString("C")</p>

            @if (Model.Stock > 0)
            {
                <span class="badge bg-success">In Stock</span>
            }
            else
            {
                <span class="badge bg-danger">Out of Stock</span>
            }

        </div>

        <div class="card-footer bg-white border-0 text-center">

            <button class="btn btn-outline-dark btn-sm w-100 mb-2"
                    onclick="location.href='@Url.Action("Details", "Products", new { id = Model.ProductId })'">
                View Details
            </button>

            @if (SignInManager.IsSignedIn(User))
            {
                <button class="btn btn-dark btn-sm w-100"
                        onclick="addToCart(@Model.ProductId)">
                    Add to Cart
                </button>
            }
            else
            {
                <button class="btn btn-secondary btn-sm w-100"
                        onclick="alert('Please log in to add items to your cart.')">
                    Add to Cart
                </button>
            }

        </div>

    </div>
</div>

