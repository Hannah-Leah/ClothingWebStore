@model List<ClothingWebStore.Models.Order>

<h2>My Orders</h2>

@if (!Model.Any())
{
    <p>No orders found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Order ID</th>
                <th>Date</th>
                <th>Total</th>
                <th>VAT</th>
                <th>Items</th>
                <th></th>
            </tr>
        </thead>

        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>#@order.OrderId</td>
                    <td>@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@order.TotalPrice.ToString("C")</td>
                    <td>@order.Vat.ToString("C")</td>
                    <td>@order.OrderItems.Sum(i => i.Quantity)</td>
                    <td>
                        <a class="btn btn-info btn-sm"
                               asp-action="Details"
                               asp-route-id="@order.OrderId">
                            Details
                        </a>

                        @if (User.IsInRole("Admin"))
                        {
                            <form asp-action="Delete"
                                  method="post"
                                  asp-route-id="@order.OrderId"
                                  style="display:inline">
                                <button class="btn btn-danger btn-sm"
                                        onclick="return confirm('Delete order?')">
                                    Delete
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}